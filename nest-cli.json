{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "i18n/**/*.json"
      },
      {
        "include": "../static",
        "outDir": "dist/static"
      },
      {
        "include": "cert/*.*"
      }
    ],
    "watchAssets": true
  }
}
